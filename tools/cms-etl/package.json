{
  "name": "@costcompare/cms-etl",
  "version": "0.0.1",
  "private": true,
  "description": "Local ETL for CMS Medicare ASC facility list and ASC Fee Schedule. Uploads derived rows to Supabase via service role. See ../../supabase/schema-design.md for the target schema.",
  "type": "module",
  "scripts": {
    "etl": "tsx src/cli.ts all",
    "etl:facilities": "tsx src/cli.ts facilities",
    "etl:rates": "tsx src/cli.ts rates",
    "etl:nppes": "tsx src/cli.ts nppes",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "adm-zip": "^0.5.16",
    "dotenv": "^16.4.5",
    "papaparse": "^5.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.7.0",
    "@types/papaparse": "^5.3.15",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
