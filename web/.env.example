# CostCompare web app — Vite env vars.
#
# For local dev, copy to `.env` in this directory and fill in from:
#   npx supabase status --workdir ../
#
# Use the *publishable* key (not the secret); it's safe to embed in the
# browser bundle because RLS enforces access on the server side.

VITE_SUPABASE_URL=http://127.0.0.1:54421
VITE_SUPABASE_ANON_KEY=<paste-the-local-publishable-key-here>
