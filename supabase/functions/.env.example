# Environment for Supabase Edge Functions (local dev).
#
# To use:
#   cp supabase/functions/.env.example supabase/functions/.env
#   npx supabase functions serve submit --env-file supabase/functions/.env --workdir /c/AI/claude/costcompare
#
# Supabase auto-injects SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY into the
# edge runtime when served locally — you do NOT need to set them here.

# Dev: stub Resend and log the confirm URL to stdout instead of sending email.
# REQUIRED in local dev. Remove in prod.
EMAIL_MODE=dev-console

# Base URL used to build the confirmation link. Must match the frontend.
APP_BASE_URL=http://localhost:5173

# Prod: set these two (via `supabase secrets set`) and drop EMAIL_MODE.
# Never commit real values.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=confirm@example.com
